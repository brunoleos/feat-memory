#!/usr/bin/env python3
"""
pre-commit hook — Bloqueia commits que violam o protocolo de auditoria.

Para contornar deliberadamente: git commit --no-verify

Este hook chama `agent-memory audit --strict --no-index`, que promove
warnings (drift de contratos) a errors. Isso garante a regra fundamental
do Manifest: código e features são commitados juntos.
"""

from __future__ import annotations

import shutil
import subprocess
import sys
from pathlib import Path


def find_project_root() -> Path | None:
    """Descobre a raiz do repositório Git."""
    try:
        out = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"],
            text=True, stderr=subprocess.DEVNULL,
        ).strip()
        if out:
            return Path(out)
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return None


def main() -> int:
    root = find_project_root()
    if root is None:
        print("[pre-commit] não foi possível localizar a raiz do repositório",
              file=sys.stderr)
        return 1

    if shutil.which("agent-memory") is None:
        print("[pre-commit] AVISO: 'agent-memory' não encontrado no PATH; "
              "pulando auditoria")
        print("  Instale com: pipx install -e <clone-do-agent-memory>",
              file=sys.stderr)
        return 0

    print("[pre-commit] auditando artefatos...")
    result = subprocess.run(
        ["agent-memory", "audit", "--strict", "--no-index"],
        cwd=root,
    )

    if result.returncode != 0:
        print("", file=sys.stderr)
        print("[pre-commit] auditoria falhou. "
              "Para contornar: git commit --no-verify",
              file=sys.stderr)

    # Aviso soft (sempre exit 0) sobre commits que tocam código sem
    # atualizar STATE.md. Roda independentemente do returncode do audit:
    # o sinal é informativo, não condicional. ADR-0016, F-0013.
    subprocess.run(
        ["agent-memory", "check-staleness-staged"],
        cwd=root,
    )

    # Guard hard (exit 1) que bloqueia commits tocando código sem bumpar
    # VERSION. No-op em projetos sem arquivo VERSION na raiz.
    bump_check = subprocess.run(
        ["agent-memory", "check-version-bump-staged"],
        cwd=root,
    )

    return result.returncode or bump_check.returncode


if __name__ == "__main__":
    sys.exit(main())
