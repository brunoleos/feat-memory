#!/usr/bin/env python3
"""
pre-commit hook — Bloqueia commits que violam o protocolo de auditoria.

Para contornar deliberadamente: git commit --no-verify

Este hook chama `feat-memory audit --strict --no-index`, que promove
warnings (drift de contratos) a errors. Isso garante a regra fundamental
do Manifest: código e features são commitados juntos.
"""

from __future__ import annotations

import shutil
import subprocess
import sys
from pathlib import Path


def find_project_root() -> Path | None:
    """Descobre a raiz do repositório Git."""
    try:
        out = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"],
            text=True, stderr=subprocess.DEVNULL,
        ).strip()
        if out:
            return Path(out)
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return None


def main() -> int:
    root = find_project_root()
    if root is None:
        print("[pre-commit] não foi possível localizar a raiz do repositório",
              file=sys.stderr)
        return 1

    if shutil.which("feat-memory") is None:
        print("[pre-commit] AVISO: 'feat-memory' não encontrado no PATH; "
              "pulando auditoria")
        print("  Instale com: pipx install -e <clone-do-feat-memory>",
              file=sys.stderr)
        return 0

    print("[pre-commit] auditando artefatos...")
    result = subprocess.run(
        ["feat-memory", "audit", "--strict", "--no-index"],
        cwd=root,
    )

    if result.returncode != 0:
        print("", file=sys.stderr)
        print("[pre-commit] auditoria falhou. "
              "Para contornar: git commit --no-verify",
              file=sys.stderr)

    # Aviso soft (sempre exit 0) sobre commits que tocam código sem
    # registrar no changelog/UNRELEASED.md. Roda independente do returncode do audit:
    # o sinal é informativo, não condicional. ADR-0016, F-0013.
    subprocess.run(
        ["feat-memory", "check-staleness-staged"],
        cwd=root,
    )

    # Gate hard (exit 1): bloqueia commits que tocam código sem mover nenhum
    # artefato de doc (.feat-memory/changelog/UNRELEASED.md, manifest/ ou decisions/). É o
    # complemento bloqueante do aviso soft acima — garante sincronia doc↔código.
    doc_sync = subprocess.run(
        ["feat-memory", "check-doc-sync-staged"],
        cwd=root,
    )

    # Guard hard (exit 1) que bloqueia commits tocando código sem bumpar
    # VERSION. No-op em projetos sem arquivo VERSION na raiz.
    bump_check = subprocess.run(
        ["feat-memory", "check-version-bump-staged"],
        cwd=root,
    )

    return result.returncode or doc_sync.returncode or bump_check.returncode


if __name__ == "__main__":
    sys.exit(main())
